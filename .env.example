# Запускать браузер в фоне (без GUI)
HEADLESS=false

# Сколько страниц Ozon проверять (1 стр ≈ 36 товаров, 3 стр = ~100)
MAX_PAGES=3

# Движок браузера: chromium | firefox | webkit
BROWSER_TYPE=chromium

# Задержка между действиями (секунды, случайное значение в диапазоне)
DELAY_MIN=1.5
DELAY_MAX=3.5

# Таймаут ожидания элементов (миллисекунды)
TIMEOUT_MS=30000

# Таймаут ожидания элементов на главной
WAIT_SELECTOR_TIMEOUT_MS=10000

# Короткий таймаут для проверки товаров на странице поиска
PRODUCT_SELECTOR_TIMEOUT_MS=5000

# Стратегия загрузки страницы: domcontentloaded | load | networkidle
NAVIGATION_WAIT=domcontentloaded

# Параметры retry при блокировке IP
MAX_RETRIES=2
RETRY_DELAY_MIN=60
RETRY_DELAY_MAX=120

# Ожидание решения капчи (секунды)
CAPTCHA_WAIT_SECONDS=60
CAPTCHA_CHECK_INTERVAL=5

# Параметры lazy loading при скролле
SCROLL_STABILIZE_THRESHOLD=3
SCROLL_MAX_ITERATIONS=20
SCROLL_WAIT_TIME=1.5

# Лимит времени выполнения скрипта (0 = без ограничения)
MAX_EXECUTION_SECONDS=0
